<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Sdkwork.Utils</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>0.10.0</Version>
    <PackageId>Sdkwork.Utils</PackageId>
    <Authors>SDKWork</Authors>
    <Description>SDKWork cross-language utility library for C#</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/sdkwork/sdkwork-utils</RepositoryUrl>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="Sdkwork.Utils.Tests/**" />
  </ItemGroup>
</Project>
