{
  "name": "@sdkwork/utils",
  "version": "0.11.0",
  "description": "SDKWork cross-language utility library for TypeScript",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bloom": {
      "types": "./dist/bloom.d.ts",
      "import": "./dist/bloom.js"
    },
    "./boolean": {
      "types": "./dist/boolean.d.ts",
      "import": "./dist/boolean.js"
    },
    "./bytes": {
      "types": "./dist/bytes.d.ts",
      "import": "./dist/bytes.js"
    },
    "./collection": {
      "types": "./dist/collection.d.ts",
      "import": "./dist/collection.js"
    },
    "./compare": {
      "types": "./dist/compare.d.ts",
      "import": "./dist/compare.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js"
    },
    "./currency": {
      "types": "./dist/currency.d.ts",
      "import": "./dist/currency.js"
    },
    "./datetime": {
      "types": "./dist/datetime.d.ts",
      "import": "./dist/datetime.js"
    },
    "./encoding": {
      "types": "./dist/encoding.d.ts",
      "import": "./dist/encoding.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.js"
    },
    "./id": {
      "types": "./dist/id.d.ts",
      "import": "./dist/id.js"
    },
    "./number": {
      "types": "./dist/number.d.ts",
      "import": "./dist/number.js"
    },
    "./object": {
      "types": "./dist/object.d.ts",
      "import": "./dist/object.js"
    },
    "./optional": {
      "types": "./dist/optional.d.ts",
      "import": "./dist/optional.js"
    },
    "./path": {
      "types": "./dist/path.d.ts",
      "import": "./dist/path.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "import": "./dist/string.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
